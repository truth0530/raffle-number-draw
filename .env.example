# 현장 번호 추첨 앱 — 환경 변수 예시
# (번호 추첨 기능은 서버/DB 없이 브라우저 안에서 동작하므로 배포 시 별도 설정이 필요 없습니다.)

# --- 유리병(QR) 응모 추첨: Postgres 필요 (Supabase 권장) ---
# 운영(Vercel 서버리스 + 수백 명 동시 접속)은 반드시 "트랜잭션 풀러"(포트 6543, pgbouncer)를 쓸 것.
#   → 연결이 statement/transaction 단위로 반납돼 대규모 동시 접속을 감당한다.
#   → 세션 풀러(5432)는 서버리스에서 연결을 붙잡아 수십 요청만으로 연결이 고갈된다(실측 장애).
# 트랜잭션 풀러에서는 Prisma 인터랙티브 트랜잭션이 끊기므로(P2028), 추첨 라우트는 배열
# 트랜잭션만 사용한다(src/app/api/draw/route.ts). pgbouncer=true 로 prepared statement 를 끈다.
# DIRECT_URL 은 마이그레이션 전용 — 세션/직결(5432)을 쓴다.
# schema 파라미터로 전용 스키마를 지정해 같은 DB의 다른 앱과 격리합니다.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?schema=raffle&pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=raffle"
# 관리자 토큰(강한 랜덤 값으로 직접 정하세요; 절대 커밋하지 마세요)
ADMIN_TOKEN="change-me"
# QR이 가리킬 공개 응모 URL(운영 배포 도메인의 /enter)
NEXT_PUBLIC_EVENT_URL="https://your-app.vercel.app/enter"
# 시나리오 테스트(/test) 진입 코드 — 기억하기 쉬운 8자리. 미설정 시 기본값 RAFFLE26.
# 샌드박스는 브라우저 로컬 전용이라 이 코드가 유출되어도 실제 행사에 영향 없음.
NEXT_PUBLIC_TEST_CODE="RAFFLE26"
